SELECT
  T0."DocEntry",
  T0."DocNum",
  T0."CardCode",
  T0."CardName",
  CASE
    T0."BPLId"
    WHEN '1' THEN 'CNA'
    WHEN '2' THEN 'FA'
  END AS "Empresa",
  T0."NumAtCard",
  T0."DocDate",
  T0."FolioNum",
  T1."ItemCode",
  T1."Quantity",
  T0."DocTotal",
  T0."Comments"
FROM
  OPDN T0
  INNER JOIN PDN1 T1 ON T0."DocEntry" = T1."DocEntry"